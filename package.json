{
  "private": true,
  "name": "setup-bun",
  "version": "2.2.0",
  "description": "Setup Bun on GitHub Actions.",
  "keywords": [
    "bun",
    "bun.js",
    "github",
    "actions",
    "setup"
  ],
  "homepage": "https://bun.sh/",
  "main": "dist/index.js",
  "repository": "git@github.com:step-security/setup-bun.git",
  "license": "MIT",
  "author": "step-security",
  "scripts": {
    "format": "prettier --write src *.yml *.json *.md",
    "build": "patch-package && esbuild --target=node24 --outfile=dist/setup/index.js --bundle --keep-names --minify --platform=node --format=cjs src/index.ts && esbuild --target=node24 --outfile=dist/cache-save/index.js --bundle --keep-names --minify --platform=node --format=cjs src/cache-save.ts",
    "start": "npm run build && node dist/setup/index.js"
  },
  "dependencies": {
    "@actions/cache": "^5.0.5",
    "@actions/core": "^2.0.3",
    "@actions/exec": "^2.0.0",
    "@actions/glob": "^0.5.1",
    "@actions/io": "^2.0.0",
    "@actions/tool-cache": "^3.0.1",
    "@iarna/toml": "^2.2.5",
    "axios": "^1.16.1",
    "compare-versions": "^6.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.12.4",
    "esbuild": "^0.25.12",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "typescript": "^4.9.5"
  },
  "overrides": {
    "brace-expansion": "^1.1.13",
    "fast-xml-builder": "^1.1.7",
    "minimatch": "^3.1.4"
  }
}
